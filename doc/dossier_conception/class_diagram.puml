@startuml
title LeadelMarche - Diagramme de classes global (MVC + metier + persistance)

skinparam classAttributeIconSize 0
skinparam dpi 300
skinparam linetype ortho
skinparam ranksep 28
skinparam nodesep 10
top to bottom direction
scale max 1600 width

package "app" as app_pkg {
  class LeadelMarcheApp {
    + main(args: String[]): void
  }

  class ApplicationContext <<Singleton>> {
    + getInstance(): ApplicationContext
    + inventoryService(): InventoryService
    + staffService(): StaffService
    + absenceService(): AbsenceService
    + scheduleService(): ScheduleService
    + customerService(): CustomerService
    + promotionCatalogService(): PromotionCatalogService
    + salesService(): SalesService
    + statisticsService(): StatisticsService
    + mailOutboxService(): MailOutboxService
  }
}

package "common" as common_pkg {
  interface Activable {
    + isActive(): boolean
    + setActive(active: boolean)
  }

  abstract class BaseEntity <<Entity>> {
    + id: String
    + active: boolean
    + createdAt: LocalDateTime
    + updatedAt: LocalDateTime
  }

  class Address {
    + line1: String
    + city: String
    + postalCode: String
    + country: String
  }

  class SearchNormalizer <<Utility>> {
    + normalize(text: String): String
    + containsNormalized(source: String, partial: String): boolean
  }
}

package "domain.inventory" as domain_inventory_pkg {
  enum ProductType {
    ALIMENTAIRE
    MEDECINE
    ELECTRONIQUE
    AUTRE
  }

  class Product <<Entity>> {
    + sku: String
    + barcode: String
    + name: String
    + description: String
    + type: ProductType
    + unitPriceHT: BigDecimal
    + vatPercent: BigDecimal
    + countryOfOrigin: String
    + supplierName: String
    + weighted: boolean
    + soldByPieceWithoutBarcode: boolean
    + expectedWeightKg: BigDecimal
    + lowStockThresholdPercent: BigDecimal
  }

  class InventoryItem <<Entity>> {
    + productId: String
    + storeId: String
    + quantity: BigDecimal
    + reservedQuantity: BigDecimal
    + availableQuantity(): BigDecimal
  }

  class Store <<Entity>> {
    + storeId: String
    + name: String
    + address: Address
    + openingHours: String
  }
}

package "domain.people" as domain_people_pkg {
  enum ContractType {
    CDI_35H
    CDI_ETUDIANT
    CDD
    INTERIM
  }

  class Employee <<Entity>> {
    + badgeNumber: String
    + firstName: String
    + lastName: String
    + homeAddress: Address
    + workAddress: Address
    + role: String
    + supervisorBadge: String
    + contractType: ContractType
    + contractWeeklyHours: int
  }

  class StaffAbsence <<Entity>> {
    + badgeNumber: String
    + absenceDate: LocalDate
    + type: String
    + note: String
  }

  class WorkShift <<Entity>> {
    + employeeId: String
    + badgeNumber: String
    + employeeName: String
    + shiftDate: LocalDate
    + startTime: LocalTime
    + endTime: LocalTime
    + paidMultiplier: BigDecimal
    + breakPlan: String
    + weekId: String
  }
}

package "domain.customer" as domain_customer_pkg {
  class LoyaltyAccount <<Entity>> {
    + cardNumber: String
    + potBalance: BigDecimal
    + createdAt: LocalDateTime
  }

  class Customer <<Entity>> {
    + firstName: String
    + lastName: String
    + email: String
    + postalCode: String
    + loyaltyCardNumber: String
    + isAnonymous: boolean
  }
}

package "domain.sales" as domain_sales_pkg {
  enum PaymentMode {
    CASH
    CARD
    MOBILE
    VOUCHER
  }

  enum SaleStatus {
    DRAFT
    FINALIZED
  }

  class POS <<Entity>> {
    + posId: String
    + name: String
    + storeId: String
    + fastCheckoutEnabled: boolean
  }

  class Sale <<Entity>> {
    + saleNumber: String
    + posId: String
    + storeId: String
    + cashierBadge: String
    + customerId: String
    + soldAt: LocalDateTime
    + subTotalHT: BigDecimal
    + totalVat: BigDecimal
    + totalTTC: BigDecimal
    + discountTotal: BigDecimal
    + loyaltyCredit: BigDecimal
    + paymentMode: PaymentMode
    + status: SaleStatus
    + recalculateTotals(lines: List<SaleLine>)
  }

  class SaleLine <<Entity>> {
    + saleId: String
    + productId: String
    + productName: String
    + unitPriceHT: BigDecimal
    + quantity: BigDecimal
    + weightKg: BigDecimal
    + lineVat: BigDecimal
    + lineTotal: BigDecimal
    + discountAmount: BigDecimal
    + recomputeTotals()
  }

  class Receipt <<Entity>> {
    + saleId: String
    + textBody: String
    + printed: boolean
    + emailed: boolean
    + customerEmail: String
  }
}

package "domain.promotion" as domain_promo_pkg {
  enum PromotionEffect {
    IMMEDIATE_DISCOUNT
    LOYALTY_POT
  }

  enum PromotionRuleType {
    BUY_X_GET_Y
    PERCENT_ON_NTH
  }

  abstract class Promotion <<Entity>> {
    + name: String
    + renewable: boolean
    + startDate: LocalDate
    + endDate: LocalDate
    + effect: PromotionEffect
    + computeDiscount(lines: List<SaleLine>): BigDecimal
  }

  class BuyXGetYPromotion {
    + xBought: int
    + yFree: int
  }

  class PercentOnNthPromotion {
    + nthItem: int
    + percentDiscount: BigDecimal
  }

  class PromotionRule <<Entity>> {
    + name: String
    + productId: String
    + startDate: LocalDate
    + endDate: LocalDate
    + renewable: boolean
    + effect: PromotionEffect
    + type: PromotionRuleType
    + buyQty: int
    + freeQty: int
    + nthItem: int
    + percentDiscount: BigDecimal
  }
}

package "service" as service_pkg {
  class InventoryService <<Service>> {
    + createProduct(product: Product)
    + updateProduct(product: Product)
    + deactivateProduct(productId: String)
    + addStock(productId: String, storeId: String, qty: BigDecimal)
    + removeStock(productId: String, storeId: String, qty: BigDecimal)
    + getStockAcrossStores(productId: String): List<InventoryItem>
    + detectLowStockAlerts(): List<String>
  }

  class StaffService <<Service>> {
    + createEmployee(employee: Employee)
    + updateEmployee(employee: Employee)
    + deactivateEmployee(employeeId: String)
  }

  class AbsenceService <<Service>> {
    + recordAbsence(badgeNumber: String, date: LocalDate, type: String, note: String)
    + listAbsences(activeOnly: boolean): List<StaffAbsence>
  }

  class ScheduleService <<Service>> {
    + generateWeeklySchedule(anyDateInWeek: LocalDate, minimumStaffPerDay: int): List<WorkShift>
    + forecastStaffingAlerts(monthsAhead: int, minimumStaffPerDay: int): List<String>
  }

  class CustomerService <<Service>> {
    + createCustomer(customer: Customer)
    + updateCustomer(customer: Customer)
    + deactivateCustomer(customerId: String)
    + findOrAnonymous(cardNumber: String): Customer
    + creditLoyalty(cardNumber: String, amount: BigDecimal)
  }

  class PromotionCatalogService <<Service>> {
    + createPromotion(...)
    + listPromotions(activeOnly: boolean): List<PromotionRule>
    + listActivePromotionsAt(date: LocalDate): List<PromotionRule>
  }

  class PromotionService <<Service>> {
    + applyPromotions(sale: Sale, lines: List<SaleLine>, customer: Customer): PromotionComputation
  }

  class PromotionComputation {
    + immediateDiscount: BigDecimal
    + loyaltyCredit: BigDecimal
    + appliedPromotions: List<String>
  }

  class FastCheckoutService <<Service>> {
    + validateScannedWeight(product: Product, measuredKg: BigDecimal): boolean
    + requestCashierHelp(posId: String, reason: String): String
  }

  class ReceiptService <<Service>> {
    + buildReceipt(sale: Sale, lines: List<SaleLine>, customer: Customer, promotions: PromotionComputation): Receipt
    + print(receipt: Receipt): String
    + email(receipt: Receipt, email: String): String
  }

  class SalesService <<Service>> {
    + startSale(posId: String, cashierBadge: String, customerCard: String): Sale
    + addLineByBarcode(saleId: String, barcode: String, qty: BigDecimal)
    + addWeightedLine(saleId: String, productType: ProductType, weightKg: BigDecimal)
    + finalizeSale(saleId: String): Receipt
  }

  class StatisticsService <<Service>> {
    + listAvailableStats()
    + compute(statId: String, start: LocalDate, end: LocalDate): BigDecimal
    + compare(...)
    + registerProductSalesStatistic(...)
    + registerPromotionSalesStatistic(...)
  }

  class MailOutboxService <<Service>> {
    + sendMail(to: String, subject: String, body: String): String
  }

  class SeedDataService <<Service>> {
    + loadDefaultData(): void
  }

  class SimplePdfService <<Service>>
}

package "persistence" as persistence_pkg {
  interface Repository<T> {
    + create(entity: T)
    + update(entity: T)
    + findById(id: String): Optional<T>
    + findAll(activeOnly: boolean): List<T>
    + searchByName(partial: String): List<T>
  }

  abstract class AbstractTextRepository<T extends BaseEntity>

  class TextFileDatabase <<Singleton>> {
    + basePath: String
    + readLines(fileName: String): List<String>
    + writeLines(fileName: String, lines: List<String>)
    + appendLine(fileName: String, line: String)
  }

  class DelimitedText <<Utility>>
  class ProductRepository
  class InventoryRepository
  class EmployeeRepository
  class AbsenceRepository
  class WorkShiftRepository
  class CustomerRepository
  class PromotionRuleRepository
  class SaleRepository
  class SaleLineRepository
  class ReceiptRepository
}

package "ui.mvc" as ui_pkg {
  class Branding <<Utility>>
  class MiniCalculatorDialog

  class MainMenuView <<View>>
  class MainMenuController <<Controller>>

  class StockView <<View>>
  class StockController <<Controller>>

  class StaffView <<View>>
  class StaffController <<Controller>>

  class CustomerView <<View>>
  class CustomerController <<Controller>>

  class POSView <<View>>
  class POSController <<Controller>>

  class SelfCheckoutView <<View>>
  class SelfCheckoutController <<Controller>>

  class PromotionView <<View>>
  class PromotionController <<Controller>>

  class StatsView <<View>>
  class StatsController <<Controller>>
}

BaseEntity ..|> Activable

Product --|> BaseEntity
InventoryItem --|> BaseEntity
Store --|> BaseEntity
Employee --|> BaseEntity
StaffAbsence --|> BaseEntity
WorkShift --|> BaseEntity
Customer --|> BaseEntity
LoyaltyAccount --|> BaseEntity
POS --|> BaseEntity
Sale --|> BaseEntity
SaleLine --|> BaseEntity
Receipt --|> BaseEntity
Promotion --|> BaseEntity
PromotionRule --|> BaseEntity
BuyXGetYPromotion --|> Promotion
PercentOnNthPromotion --|> Promotion

Store "1" o-- "many" POS
Store "1" o-- "many" InventoryItem
Product "1" o-- "many" InventoryItem
Employee "0..1" --> "0..*" Employee : supervisor
Employee "1" o-- "many" StaffAbsence
Employee "1" o-- "many" WorkShift
Customer "0..1" o-- "1" LoyaltyAccount
Sale "1" o-- "1..*" SaleLine
Sale "1" --> "1" POS
Sale "1" --> "1" Employee : cashier
Sale "1" --> "1" Customer
Receipt "1" --> "1" Sale
PromotionRule "0..*" --> "0..*" Product

PromotionCatalogService --> PromotionRuleRepository
PromotionService --> PromotionCatalogService
PromotionService --> SaleLine

InventoryService --> ProductRepository
InventoryService --> InventoryRepository

StaffService --> EmployeeRepository
AbsenceService --> AbsenceRepository
ScheduleService --> WorkShiftRepository
ScheduleService --> StaffService
ScheduleService --> AbsenceService
ScheduleService --> SimplePdfService
ScheduleService --> TextFileDatabase

CustomerService --> CustomerRepository

SalesService --> SaleRepository
SalesService --> SaleLineRepository
SalesService --> InventoryService
SalesService --> PromotionService
SalesService --> ReceiptService
SalesService --> CustomerService
SalesService --> FastCheckoutService

ReceiptService --> ReceiptRepository

StatisticsService --> SaleRepository
StatisticsService --> SaleLineRepository
StatisticsService --> ReceiptRepository
StatisticsService --> CustomerRepository
StatisticsService --> AbsenceService

MailOutboxService --> TextFileDatabase
SeedDataService --> InventoryService
SeedDataService --> CustomerService
SeedDataService --> StaffService
SeedDataService --> AbsenceService
SeedDataService --> ScheduleService

Repository <|.. AbstractTextRepository
AbstractTextRepository <|.. ProductRepository
AbstractTextRepository <|.. InventoryRepository
AbstractTextRepository <|.. EmployeeRepository
AbstractTextRepository <|.. AbsenceRepository
AbstractTextRepository <|.. WorkShiftRepository
AbstractTextRepository <|.. CustomerRepository
AbstractTextRepository <|.. PromotionRuleRepository
AbstractTextRepository <|.. SaleRepository
AbstractTextRepository <|.. SaleLineRepository
AbstractTextRepository <|.. ReceiptRepository
AbstractTextRepository ..> DelimitedText

Repository ..> TextFileDatabase : persistance fichier texte

MainMenuController -down-> StockController
MainMenuController -down-> StaffController
MainMenuController -down-> CustomerController
MainMenuController -down-> POSController
MainMenuController -down-> SelfCheckoutController
MainMenuController -down-> PromotionController
MainMenuController -down-> StatsController

StockController --> InventoryService
StaffController --> StaffService
StaffController --> AbsenceService
StaffController --> ScheduleService
CustomerController --> CustomerService
POSController --> SalesService
SelfCheckoutController --> SalesService
SelfCheckoutController --> InventoryService
PromotionController --> PromotionCatalogService
StatsController --> StatisticsService
StatsController --> MailOutboxService

MainMenuView --> MainMenuController
StockView --> StockController
StaffView --> StaffController
CustomerView --> CustomerController
POSView --> POSController
SelfCheckoutView --> SelfCheckoutController
PromotionView --> PromotionController
StatsView --> StatsController

MainMenuView ..> Branding
StockView ..> Branding
StaffView ..> Branding
CustomerView ..> Branding
POSView ..> Branding
SelfCheckoutView ..> Branding
PromotionView ..> Branding
StatsView ..> Branding
POSView ..> MiniCalculatorDialog
SelfCheckoutView ..> MiniCalculatorDialog

ApplicationContext -down-> MainMenuController
ApplicationContext -down-> TextFileDatabase
ApplicationContext -down-> InventoryService
ApplicationContext -down-> StaffService
ApplicationContext -down-> AbsenceService
ApplicationContext -down-> ScheduleService
ApplicationContext -down-> CustomerService
ApplicationContext -down-> PromotionCatalogService
ApplicationContext -down-> PromotionService
ApplicationContext -down-> FastCheckoutService
ApplicationContext -down-> ReceiptService
ApplicationContext -down-> SalesService
ApplicationContext -down-> StatisticsService
ApplicationContext -down-> MailOutboxService
ApplicationContext -down-> SeedDataService

LeadelMarcheApp --> ApplicationContext
LeadelMarcheApp --> MainMenuController

' ===== Layout control (compact vertical / rendu plus carre)
' -- ancrage des packages en grille verticale
app_pkg -[hidden]down- common_pkg
common_pkg -[hidden]down- service_pkg
service_pkg -[hidden]down- persistence_pkg
persistence_pkg -[hidden]down- ui_pkg

common_pkg -[hidden]left- domain_inventory_pkg
domain_inventory_pkg -[hidden]down- domain_people_pkg
domain_people_pkg -[hidden]down- domain_customer_pkg
domain_customer_pkg -[hidden]down- domain_sales_pkg
domain_sales_pkg -[hidden]down- domain_promo_pkg
domain_promo_pkg -[hidden]right- persistence_pkg

' -- ancrage vertical interne
LeadelMarcheApp -[hidden]down- ApplicationContext
ApplicationContext -[hidden]down- MainMenuController

InventoryService -[hidden]down- ScheduleService
ScheduleService -[hidden]down- SalesService
SalesService -[hidden]down- StatisticsService
StatisticsService -[hidden]down- MailOutboxService

ProductRepository -[hidden]down- EmployeeRepository
EmployeeRepository -[hidden]down- CustomerRepository
CustomerRepository -[hidden]down- SaleRepository
SaleRepository -[hidden]down- ReceiptRepository

MainMenuController -[hidden]down- StockController
StockController -[hidden]down- StaffController
